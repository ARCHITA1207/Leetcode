#include <stdlib.h>
typedef struct 
{
    char *name;
    int height;
} Person;
int cmp(const void *a, const void *b)
{
    Person *p1 = (Person*)a;
    Person *p2 = (Person*)b;
    return p2->height - p1->height;   
}
char** sortPeople(char** names, int namesSize,
                  int* heights, int heightsSize,
                  int* returnSize)
{
    Person *arr = malloc(namesSize * sizeof(Person));
    for(int i = 0; i < namesSize; i++)
    {
        arr[i].name = names[i];
        arr[i].height = heights[i];
    }
    qsort(arr, namesSize, sizeof(Person), cmp);
    char **ans = malloc(namesSize * sizeof(char*));
    for(int i = 0; i < namesSize; i++)
        ans[i] = arr[i].name;
    *returnSize = namesSize;
    return ans;
}
