#include <stdio.h>
#include <stdbool.h>
int countSegments(char * s){
    int count = 0;
    bool inSegment = false;
    for(int i = 0; s[i] != '\0'; i++){
        if(s[i] != ' '){
            if(!inSegment){
                count++;
                inSegment = true;
            }
        } 
        else
         {
            inSegment = false;
        }
    }
    return count;
}
